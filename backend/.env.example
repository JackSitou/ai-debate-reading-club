# AI 杠精读书会 - 后端环境变量
# 复制为 .env 并填入你的 API Key

# 选择默认大模型提供商: huggingface | openrouter | openai
DEFAULT_PROVIDER=openrouter

# HuggingFace API Token（免费获取: https://huggingface.co/settings/tokens）
HF_API_KEY=

# OpenRouter API Key（免费获取: https://openrouter.ai/keys）
OPENROUTER_KEY=

# OpenAI API Key（可选）
OPENAI_KEY=

# 服务端口号
PORT=3000
